# ══════════════════════════════════════════════════════════════════════════════
# IFL Platform — 통합 백엔드 환경변수
#
# [REQUIRED] = 반드시 설정해야 하는 필수 변수
# [OPTIONAL] = 기본값이 있거나 선택적인 변수
#
# 사용법:
#   cp .env.example .env
#   # 또는 대화형 생성: ./scripts/generate-env.sh
#   # 검증: ./scripts/validate-env.sh
# ══════════════════════════════════════════════════════════════════════════════

# ── Environment ──────────────────────────────────────────────────────────────
# [OPTIONAL]
ENVIRONMENT=development

# ── Database ──────────────────────────────────────────────────────────────────
# [REQUIRED]
DATABASE_URL=postgresql+asyncpg://user:pass@db:5432/ifl
DATABASE_URL_SYNC=postgresql://user:pass@db:5432/ifl
POSTGRES_USER=user
POSTGRES_PASSWORD=pass
POSTGRES_DB=ifl

# ── Redis / Celery ────────────────────────────────────────────────────────────
# [OPTIONAL]
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
# [REQUIRED]
JWT_SECRET_KEY=change-me-in-production
# [OPTIONAL]
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Google OAuth ──────────────────────────────────────────────────────────────
# [REQUIRED]
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# [OPTIONAL]
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ── Frontend ──────────────────────────────────────────────────────────────────
# [OPTIONAL]
FRONTEND_URL=http://localhost:3000

# ── Anthropic (Claude API) ────────────────────────────────────────────────────
# [REQUIRED]
ANTHROPIC_API_KEY=
# [OPTIONAL]
CLAUDE_MODEL=claude-opus-4-6

# ── OpenAI (임베딩) ───────────────────────────────────────────────────────────
# [OPTIONAL]
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# ── 평가 시스템 ──────────────────────────────────────────────────────────────
# [OPTIONAL]
FORMATIVE_SERVE_COUNT=5
SUMMATIVE_SERVE_COUNT=5
TIMESTAMP_TOLERANCE_SECONDS=120

# ── HeyGen (영상 자동 생성) ───────────────────────────────────────────────────
# [REQUIRED]
HEYGEN_API_KEY=
# [OPTIONAL]
HEYGEN_BASE_URL=https://api.heygen.com
HEYGEN_AVATAR_ID=
HEYGEN_WEBHOOK_SECRET=
HEYGEN_CALLBACK_URL=http://localhost:8000/api/v1/webhooks/heygen

# ── TTS: ElevenLabs (primary) ────────────────────────────────────────────────
# [REQUIRED]
ELEVENLABS_API_KEY=
# [OPTIONAL]
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ── TTS: Google Cloud (fallback) ─────────────────────────────────────────────
# [OPTIONAL]
GOOGLE_TTS_CREDENTIALS_JSON=
GOOGLE_TTS_LANGUAGE_CODE=ko-KR
GOOGLE_TTS_VOICE_NAME=ko-KR-Neural2-A

# ── AWS S3 ────────────────────────────────────────────────────────────────────
# [REQUIRED]
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=ifl-platform-videos
# [OPTIONAL]
AWS_REGION=ap-northeast-2
S3_PREFIX=heygen/
S3_PPT_PREFIX=ppt/
S3_PRESIGNED_EXPIRATION=3600

# ── Stripe 결제 ──────────────────────────────────────────────────────────────
# [REQUIRED]
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# [OPTIONAL]
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=

# ── 번역 ─────────────────────────────────────────────────────────────────────
# [OPTIONAL]
DEEPL_API_KEY=

# ── 집중 경고 ────────────────────────────────────────────────────────────────
# [OPTIONAL]
ATTENTION_HEARTBEAT_INTERVAL_SECONDS=10
ATTENTION_NO_RESPONSE_TIMEOUT_SECONDS=30

# ── 알림 / 폴링 ──────────────────────────────────────────────────────────────
# [OPTIONAL]
NOTIFICATION_WEBHOOK_URL=
POLLING_INTERVAL_SECONDS=600

# ── pgvector ─────────────────────────────────────────────────────────────────
# [OPTIONAL]
SIMILARITY_THRESHOLD=0.7

# ── 도메인/SSL (프로덕션 전용) ────────────────────────────────────────────────
# [OPTIONAL]
DOMAIN=localhost
SSL_EMAIL=
