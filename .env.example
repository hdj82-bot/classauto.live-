# ══════════════════════════════════════════════════════════════════════════════
# IFL Platform — 통합 백엔드 환경변수
#
# [REQUIRED] = 반드시 설정해야 하는 필수 변수
# [OPTIONAL] = 기본값이 있거나 선택적인 변수
#
# 사용법:
#   cp .env.example .env
#   # 또는 대화형 생성: ./scripts/generate-env.sh
#   # 검증: ./scripts/validate-env.sh
# ══════════════════════════════════════════════════════════════════════════════

# ── Environment ──────────────────────────────────────────────────────────────
# [OPTIONAL]
ENVIRONMENT=development

# ── Database ──────────────────────────────────────────────────────────────────
# [REQUIRED]
DATABASE_URL=postgresql+asyncpg://user:pass@db:5432/ifl
DATABASE_URL_SYNC=postgresql://user:pass@db:5432/ifl
POSTGRES_USER=user
POSTGRES_PASSWORD=pass
POSTGRES_DB=ifl

# ── Redis / Celery ────────────────────────────────────────────────────────────
# [OPTIONAL]
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
# [REQUIRED]
JWT_SECRET_KEY=change-me-in-production
# [OPTIONAL]
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Google OAuth ──────────────────────────────────────────────────────────────
# [REQUIRED]
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# [OPTIONAL]
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ── Frontend ──────────────────────────────────────────────────────────────────
# [OPTIONAL]
FRONTEND_URL=http://localhost:3000
# [OPTIONAL] FRONTEND_URL 외 추가 CORS 허용 오리진(쉼표 구분) — apex/www/커스텀 도메인.
# 예: https://classauto.live,https://www.classauto.live
CORS_EXTRA_ORIGINS=
# [OPTIONAL] Vercel 프리뷰(*.vercel.app)에서 API 호출 허용. 프리뷰 테스트 시 true.
CORS_ALLOW_VERCEL_PREVIEWS=false
# [OPTIONAL] 프론트엔드(Next.js)가 호출할 API 베이스 URL.
# 프로덕션에서는 https://api.<도메인> 형태로 .env.production 에서 덮어쓴다.
NEXT_PUBLIC_API_URL=http://localhost:8000
# [REQUIRED in prod] 프론트엔드 빌드 타임 변수 — Vercel 프로젝트 env 로 설정한다.
#   NEXT_PUBLIC_SITE_URL: 사이트 정식 origin(메타/링크 생성용). 예: https://classauto.live
#   아래 3개는 next/image remotePatterns 허용 호스트 — 미설정 시 해당 이미지가
#   Image Optimizer 에서 차단되어 아바타/영상 썸네일이 깨진다(조용히 실패).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_S3_PUBLIC_BUCKET_HOST=
NEXT_PUBLIC_HEYGEN_CDN_HOST=

# ── Anthropic (Claude API) ────────────────────────────────────────────────────
# [REQUIRED]
ANTHROPIC_API_KEY=
# [OPTIONAL]
CLAUDE_MODEL=claude-opus-4-6
SCRIPT_MODEL=claude-sonnet-4-6         # 스크립트 생성 모델
QA_MODEL=claude-opus-4-6               # Q&A 응답 모델
SCRIPT_MAX_TOKENS=2048                 # 스크립트 생성 최대 토큰
CLAUDE_INPUT_COST_PER_M=3.00          # Claude 입력 비용 ($/M tokens)
CLAUDE_OUTPUT_COST_PER_M=15.00        # Claude 출력 비용 ($/M tokens)

# ── OpenAI (임베딩) ───────────────────────────────────────────────────────────
# [OPTIONAL]
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# ── 평가 시스템 ──────────────────────────────────────────────────────────────
# [OPTIONAL]
FORMATIVE_SERVE_COUNT=5
SUMMATIVE_SERVE_COUNT=5
TIMESTAMP_TOLERANCE_SECONDS=120

# ── HeyGen (영상 자동 생성) ───────────────────────────────────────────────────
# [REQUIRED]
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID_MALE=
HEYGEN_AVATAR_ID_FEMALE=
HEYGEN_WEBHOOK_SECRET=
# [OPTIONAL]
HEYGEN_BASE_URL=https://api.heygen.com
# Deprecated. _MALE 가 비어 있을 때만 fallback. 신규 환경은 _MALE/_FEMALE 사용.
HEYGEN_AVATAR_ID=
HEYGEN_CALLBACK_URL=http://localhost:8000/api/v1/webhooks/heygen
# 영상 1초당 USD 단가 — API 종량제 실측 기준 약 $1/min = 0.0167.
HEYGEN_COST_USD_PER_SECOND=0.0167
# 렌더 해상도. 테스트·베타 기본 720p. 베타 후 1920×1080 상향 가능.
HEYGEN_DIMENSION_WIDTH=1280
HEYGEN_DIMENSION_HEIGHT=720
# mock 모드: true 면 실제 HeyGen API 호출 생략 → 크레딧 ₩0 (로컬/테스트).
HEYGEN_MOCK=false
# mock 완료 처리용 placeholder 영상 URL (비우면 mock 렌더는 완료되지 않음).
HEYGEN_MOCK_VIDEO_URL=
# 예산 서킷 브레이커: create_video 직전 누적 비용 검사. 0 이면 비활성.
# 테스트 단계 기본 일 $3 / 월 $15. 베타 시 상향(예: 일 20 / 월 150).
HEYGEN_DAILY_BUDGET_USD=3.0
HEYGEN_MONTHLY_BUDGET_USD=15.0

# ── TTS: ElevenLabs (primary) ────────────────────────────────────────────────
# [REQUIRED]
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID_MALE=
ELEVENLABS_VOICE_ID_FEMALE=
# [OPTIONAL]
# Deprecated. _MALE 가 비어 있을 때만 fallback. 신규 환경은 _MALE/_FEMALE 사용.
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ── TTS: Google Cloud (fallback) ─────────────────────────────────────────────
# [OPTIONAL]
GOOGLE_TTS_CREDENTIALS_JSON=
GOOGLE_TTS_LANGUAGE_CODE=ko-KR
GOOGLE_TTS_VOICE_NAME=ko-KR-Neural2-A

# ── AWS S3 ────────────────────────────────────────────────────────────────────
# [REQUIRED]
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=ifl-platform-videos
# [OPTIONAL]
AWS_REGION=ap-northeast-2
S3_PREFIX=heygen/
S3_PPT_PREFIX=ppt/
S3_PRESIGNED_EXPIRATION=3600
BACKUP_S3_PREFIX=backups/

# ── Stripe 결제 ──────────────────────────────────────────────────────────────
# [OPTIONAL] 1단계 베타 무료 배포는 결제 비활성. 비워두면 /api/v1/payment 가 503 으로 차단됨.
# Phase 7 유료 전환 시 Stripe Test mode 키 또는 Live 키 입력 + config.py:_REQUIRED_IN_PROD 에 다시 추가.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=

# ── 번역 ─────────────────────────────────────────────────────────────────────
# [OPTIONAL]
DEEPL_API_KEY=

# ── 출석 판단 기준 ──────────────────────────────────────────────────────────────
# [OPTIONAL]
DEFAULT_LIVE_DEADLINE_MINUTES=30       # 기본 라이브 마감 시간(분)

# ── 집중 경고 ────────────────────────────────────────────────────────────────
# [OPTIONAL]
ATTENTION_HEARTBEAT_INTERVAL_SECONDS=10
ATTENTION_NO_RESPONSE_TIMEOUT_SECONDS=30

# ── 알림 / 폴링 ──────────────────────────────────────────────────────────────
# [OPTIONAL]
NOTIFICATION_WEBHOOK_URL=
POLLING_INTERVAL_SECONDS=600

# ── pgvector ─────────────────────────────────────────────────────────────────
# [OPTIONAL]
SIMILARITY_THRESHOLD=0.7

# ── Sentry (에러 추적) ────────────────────────────────────────────────────────
# [OPTIONAL]
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
# 프론트엔드용 (NEXT_PUBLIC_ 접두어 필수)
NEXT_PUBLIC_SENTRY_DSN=

# ── 도메인/SSL (프로덕션 전용) ────────────────────────────────────────────────
# [OPTIONAL]
DOMAIN=localhost
SSL_EMAIL=

# ── GHCR 이미지 태그 (프로덕션 전용) ──────────────────────────────────────────
# [OPTIONAL] docker-compose.prod.yml 의 backend/worker/beat/frontend 가
# ghcr.io/hdj82-bot/ifl-{backend,frontend}:${IFL_IMAGE_TAG} 로 pull 한다.
# 기본 latest. 특정 SHA 로 핀하거나 롤백할 때 sha-abc1234 등으로 덮어쓰기.
IFL_IMAGE_TAG=latest
