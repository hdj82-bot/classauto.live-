# ── Database ──────────────────────────────────────────────────────────────────
# FastAPI(asyncpg): postgresql+asyncpg://  |  NestJS(Prisma)/Pipeline: postgresql://
DATABASE_URL=postgresql+asyncpg://user:pass@db:5432/ifl
DATABASE_URL_SYNC=postgresql://user:pass@db:5432/ifl
POSTGRES_USER=user
POSTGRES_PASSWORD=pass
POSTGRES_DB=ifl

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
# 반드시 32자 이상의 랜덤 문자열로 변경 (예: openssl rand -hex 32)
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Google Cloud Console > API 및 서비스 > 사용자 인증 정보에서 발급
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
# NestJS auth 서비스용 (feat/auth)
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
# Pipeline Google Cloud TTS/Translate용 서비스 계정
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Anthropic (Claude API) ────────────────────────────────────────────────────
# 문제 자동 생성 + 스크립트 생성에 필요. https://console.anthropic.com
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-6

# ── OpenAI (파이프라인 임베딩용, 선택) ───────────────────────────────────────
OPENAI_API_KEY=

# ── 평가 시스템 튜닝 ──────────────────────────────────────────────────────────
FORMATIVE_SERVE_COUNT=5
SUMMATIVE_SERVE_COUNT=5
TIMESTAMP_TOLERANCE_SECONDS=120

# ── HeyGen (영상 자동 생성) ───────────────────────────────────────────────────
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_WEBHOOK_SECRET=
HEYGEN_CALLBACK_URL=http://localhost:8001/api/webhooks/heygen

# ── TTS: ElevenLabs (primary) ────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ── TTS: Google Cloud (fallback) ─────────────────────────────────────────────
GOOGLE_TTS_CREDENTIALS_JSON=
GOOGLE_TTS_LANGUAGE_CODE=ko-KR
GOOGLE_TTS_VOICE_NAME=ko-KR-Neural2-A

# ── AWS S3 (파일 업로드) ──────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=ifl-platform-videos
AWS_REGION=ap-northeast-2
S3_PREFIX=heygen/

# ── 알림 / 폴링 ───────────────────────────────────────────────────────────────
NOTIFICATION_WEBHOOK_URL=
POLLING_INTERVAL_SECONDS=600

# ── 기타 AI API ───────────────────────────────────────────────────────────────
DEEPL_API_KEY=
GOOGLE_TTS_KEY=
GOOGLE_TRANSLATE_KEY=
GEMINI_API_KEY=
