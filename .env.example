# ══════════════════════════════════════════════════════════════════════════════
# IFL Platform — 통합 백엔드 환경변수
# ══════════════════════════════════════════════════════════════════════════════

# ── Environment ──────────────────────────────────────────────────────────────
ENVIRONMENT=development

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@db:5432/ifl
DATABASE_URL_SYNC=postgresql://user:pass@db:5432/ifl
POSTGRES_USER=user
POSTGRES_PASSWORD=pass
POSTGRES_DB=ifl

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Anthropic (Claude API) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-6

# ── OpenAI (임베딩) ───────────────────────────────────────────────────────────
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# ── 평가 시스템 ──────────────────────────────────────────────────────────────
FORMATIVE_SERVE_COUNT=5
SUMMATIVE_SERVE_COUNT=5
TIMESTAMP_TOLERANCE_SECONDS=120

# ── HeyGen (영상 자동 생성) ───────────────────────────────────────────────────
HEYGEN_API_KEY=
HEYGEN_BASE_URL=https://api.heygen.com
HEYGEN_AVATAR_ID=
HEYGEN_WEBHOOK_SECRET=
HEYGEN_CALLBACK_URL=http://localhost:8000/api/v1/webhooks/heygen

# ── TTS: ElevenLabs (primary) ────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ── TTS: Google Cloud (fallback) ─────────────────────────────────────────────
GOOGLE_TTS_CREDENTIALS_JSON=
GOOGLE_TTS_LANGUAGE_CODE=ko-KR
GOOGLE_TTS_VOICE_NAME=ko-KR-Neural2-A

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
S3_BUCKET=ifl-platform-videos
S3_PREFIX=heygen/
S3_PPT_PREFIX=ppt/
S3_PRESIGNED_EXPIRATION=3600

# ── Stripe 결제 ──────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PRO=

# ── 번역 ─────────────────────────────────────────────────────────────────────
DEEPL_API_KEY=

# ── 집중 경고 ────────────────────────────────────────────────────────────────
ATTENTION_HEARTBEAT_INTERVAL_SECONDS=10
ATTENTION_NO_RESPONSE_TIMEOUT_SECONDS=30

# ── 알림 / 폴링 ──────────────────────────────────────────────────────────────
NOTIFICATION_WEBHOOK_URL=
POLLING_INTERVAL_SECONDS=600

# ── pgvector ─────────────────────────────────────────────────────────────────
SIMILARITY_THRESHOLD=0.7
