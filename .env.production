# ══════════════════════════════════════════════════════════════════════════════
# IFL Platform — Production 환경
# 배포 전 모든 CHANGE_ME 값을 반드시 변경하세요!
# ══════════════════════════════════════════════════════════════════════════════

ENVIRONMENT=production

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ifl_prod:CHANGE_ME_DB_PASSWORD@db:5432/ifl_prod
DATABASE_URL_SYNC=postgresql://ifl_prod:CHANGE_ME_DB_PASSWORD@db:5432/ifl_prod
POSTGRES_USER=ifl_prod
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=ifl_prod

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=https://CHANGE_ME_DOMAIN
NEXT_PUBLIC_API_URL=https://api.CHANGE_ME_DOMAIN

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=CHANGE_ME
GOOGLE_OAUTH_CLIENT_SECRET=CHANGE_ME
GOOGLE_OAUTH_REDIRECT_URI=https://api.CHANGE_ME_DOMAIN/api/auth/google/callback

# ── Anthropic (Claude API) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=CHANGE_ME
CLAUDE_MODEL=claude-sonnet-4-6

# ── OpenAI (임베딩) ──────────────────────────────────────────────────────────
OPENAI_API_KEY=CHANGE_ME
EMBEDDING_MODEL=text-embedding-3-small

# ── HeyGen (영상 자동 생성) ──────────────────────────────────────────────────
HEYGEN_API_KEY=CHANGE_ME
HEYGEN_BASE_URL=https://api.heygen.com
HEYGEN_AVATAR_ID=CHANGE_ME
HEYGEN_WEBHOOK_SECRET=CHANGE_ME
HEYGEN_CALLBACK_URL=https://api.CHANGE_ME_DOMAIN/api/v1/webhooks/heygen

# ── TTS: ElevenLabs (primary) ───────────────────────────────────────────────
ELEVENLABS_API_KEY=CHANGE_ME
ELEVENLABS_VOICE_ID=CHANGE_ME
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ── TTS: Google Cloud (fallback) ────────────────────────────────────────────
GOOGLE_TTS_CREDENTIALS_JSON=
GOOGLE_TTS_LANGUAGE_CODE=ko-KR
GOOGLE_TTS_VOICE_NAME=ko-KR-Neural2-A

# ── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_REGION=ap-northeast-2
S3_BUCKET=CHANGE_ME_BUCKET_NAME
S3_PREFIX=heygen/
S3_PPT_PREFIX=ppt/
S3_PRESIGNED_EXPIRATION=3600

# ── Stripe 결제 ──────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=CHANGE_ME
STRIPE_WEBHOOK_SECRET=CHANGE_ME
STRIPE_PRICE_BASIC=CHANGE_ME
STRIPE_PRICE_PRO=CHANGE_ME

# ── 번역 ────────────────────────────────────────────────────────────────────
DEEPL_API_KEY=CHANGE_ME

# ── 평가 시스템 ─────────────────────────────────────────────────────────────
FORMATIVE_SERVE_COUNT=5
SUMMATIVE_SERVE_COUNT=5
TIMESTAMP_TOLERANCE_SECONDS=120

# ── 출석 판단 기준 ──────────────────────────────────────────────────────────
DEFAULT_LIVE_DEADLINE_MINUTES=30

# ── 집중 경고 ───────────────────────────────────────────────────────────────
ATTENTION_HEARTBEAT_INTERVAL_SECONDS=10
ATTENTION_NO_RESPONSE_TIMEOUT_SECONDS=30

# ── pgvector ────────────────────────────────────────────────────────────────
SIMILARITY_THRESHOLD=0.7

# ── 알림 / 폴링 ─────────────────────────────────────────────────────────────
NOTIFICATION_WEBHOOK_URL=
POLLING_INTERVAL_SECONDS=300

# ── Sentry (에러 추적) ──────────────────────────────────────────────────────
SENTRY_DSN=CHANGE_ME
SENTRY_TRACES_SAMPLE_RATE=0.1
# 프론트엔드용 (NEXT_PUBLIC_ 접두어 필수)
NEXT_PUBLIC_SENTRY_DSN=CHANGE_ME

# ── 도메인 (nginx) ──────────────────────────────────────────────────────────
DOMAIN=CHANGE_ME_DOMAIN

# ── GHCR 이미지 태그 ────────────────────────────────────────────────────────
# CI 가 main 머지 시 :latest 를 push 한다. 특정 SHA 로 핀하거나 롤백할 때 sha-abc1234 식으로 변경.
IFL_IMAGE_TAG=latest
