# ══════════════════════════════════════════════════════════════════════════════
# IFL Platform — Production 환경
# ══════════════════════════════════════════════════════════════════════════════

ENVIRONMENT=production

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ifl_prod:CHANGE_ME@db:5432/ifl_prod
DATABASE_URL_SYNC=postgresql://ifl_prod:CHANGE_ME@db:5432/ifl_prod
POSTGRES_USER=ifl_prod
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=ifl_prod

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_PRODUCTION_SECRET

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=https://ifl-platform.com
NEXT_PUBLIC_API_URL=https://api.ifl-platform.com

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://api.ifl-platform.com/api/auth/google/callback

# ── 외부 API 키 ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
HEYGEN_API_KEY=
HEYGEN_CALLBACK_URL=https://api.ifl-platform.com/api/v1/webhooks/heygen
ELEVENLABS_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=ifl-platform-videos
DEEPL_API_KEY=
