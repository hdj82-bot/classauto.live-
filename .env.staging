# ══════════════════════════════════════════════════════════════════════════════
# IFL Platform — Staging 환경
# ══════════════════════════════════════════════════════════════════════════════

ENVIRONMENT=staging

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ifl_staging:CHANGE_ME@db:5432/ifl_staging
DATABASE_URL_SYNC=postgresql://ifl_staging:CHANGE_ME@db:5432/ifl_staging
POSTGRES_USER=ifl_staging
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=ifl_staging

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_STAGING_SECRET

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=https://staging.ifl-platform.com
NEXT_PUBLIC_API_URL=https://api-staging.ifl-platform.com

# ── 외부 API 키 (스테이징 전용) ──────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://api-staging.ifl-platform.com/api/auth/google/callback
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
HEYGEN_API_KEY=
HEYGEN_CALLBACK_URL=https://api-staging.ifl-platform.com/api/v1/webhooks/heygen
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=ifl-staging-videos
